    <!-- http://purl.obolibrary.org/obo/MF_0000041 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/MF_0000041">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OCCO_00000011"/>
        <obo:IAO_0000115>A mental disposition to represent a proposition to be true.</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/mf.owl"/>
        <rdfs:comment>Judging is a mental process that brings a belief into existence. Judging differently may also bring that belief out of existence.

An act of believing is just thinking about a belief.

Beliefs typically cause us to behave in ways that are characteristic with the content of that belief. However, this is not a necessary feature for the existence of the belief.</rdfs:comment>
        <rdfs:label xml:lang="en">belief</rdfs:label>
    </owl:Class>
    


